# ============================================================
# OpcnySimulator Agent Worker — Environment Variables
# ============================================================

# --- Core ---
ENVIRONMENT=development          # development | production
LOG_LEVEL=INFO
AGENT_API_PORT=8001              # Port pre health check API (iný ako hlavná appka)
INTERNAL_API_KEY=                # Zdieľaný kľúč pre komunikáciu s hlavnou appkou

# --- Database (zdieľaná PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/opcnysimulator

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_MAX_TOKENS=4096

# --- Discord ---
DISCORD_BOT_TOKEN=               # Bot token pre discord.py
DISCORD_WEBHOOK_URL=             # Webhook URL pre posting do kanála
DISCORD_NOTIFICATION_CHANNEL_ID= # Kanál pre notifikácie Mirovi
DISCORD_MIRO_USER_ID=            # Miro's Discord user ID pre DM notifikácie

# --- X / Twitter ---
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# --- Instagram (Meta Graph API) ---
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- Google Analytics 4 ---
GA4_PROPERTY_ID=                 # Formát: properties/XXXXXXXX
GA4_CREDENTIALS_JSON=            # Base64-encoded service account JSON

# --- Scheduler ---
CONTENT_POST_CRON=0 9,13,18 * * *   # Posty o 9:00, 13:00, 18:00
ANALYTICS_DAILY_CRON=0 6 * * *       # Denný report o 6:00
ANALYTICS_WEEKLY_CRON=0 7 * * 1      # Týždenný report v pondelok o 7:00
REVIEW_CHECK_CRON=*/30 * * * *       # Kontrola nových článkov každých 30 min

# --- Notifications ---
NOTIFICATION_METHOD=discord      # discord | telegram
TELEGRAM_BOT_TOKEN=              # Ak preferuješ Telegram
TELEGRAM_CHAT_ID=
